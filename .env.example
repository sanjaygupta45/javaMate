# JavaMate - Environment Variables Template

# application profile
SPRING_PROFILES_ACTIVE=local

# Cloud SQL Database Configuration
# Using same database as production
CLOUD_SQL_HOST=34.173.28.162
CLOUD_SQL_DATABASE=javamate
CLOUD_SQL_USERNAME=javamate
MYSQL_PASSWORD=your-mysql-password

# Mistral AI API Key
# Get your key from: https://console.mistral.ai/
MISTRAL_API_KEY=your-mistral-api-key

# Qdrant Vector Database API Key
# Get your key from: https://cloud.qdrant.io/
QDRANT_API_KEY=your-qdrant-api-key

# JWT Secret (optional for local - has default)
# JWT_SECRET=your-jwt-secret

# Google OAuth2 client IDs (comma-separated if multiple frontend apps)
# GOOGLE_OAUTH_CLIENT_IDS=your-web-client-id.apps.googleusercontent.com
# Optional: accepted Google token issuers
# GOOGLE_OAUTH_ACCEPTED_ISSUERS=https://accounts.google.com,accounts.google.com

# Optional: allowed frontend origins for CORS (comma-separated)
# APP_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,https://java-mate-fe.vercel.app

# OpenTelemetry (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

