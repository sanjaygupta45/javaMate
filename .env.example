# JavaMate - Environment Variables Template

# application profile
SPRING_PROFILES_ACTIVE=local

# Cloud SQL Database Configuration
# Using same database as production
CLOUD_SQL_HOST=34.173.28.162
CLOUD_SQL_DATABASE=javamate
CLOUD_SQL_USERNAME=javamate
MYSQL_PASSWORD=your-mysql-password

# Mistral AI API Key
# Get your key from: https://console.mistral.ai/
MISTRAL_API_KEY=your-mistral-api-key

# Qdrant Vector Database API Key
# Get your key from: https://cloud.qdrant.io/
QDRANT_API_KEY=your-qdrant-api-key

# JWT Secret (optional for local - has default)
# JWT_SECRET=your-jwt-secret

# OpenTelemetry (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

